# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketplace
DB_USER=postgres
DB_PASSWORD=postgres

POSTGRES_USER=vsqr
POSTGRES_PASSWORD=vsqr
POSTGRES_DB=vsqr

# JWT
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d

# NotiSend Email API (https://notisend.ru/dev/email/api/)
NOTISEND_API_KEY=your-api-key-from-notisend-cabinet
# Optional: base URL if different (default: https://api.notisend.ru)
# NOTISEND_API_URL=https://api.notisend.ru
# Sender email (must be verified in NotiSend)
NOTISEND_FROM_EMAIL=noreply@yourdomain.com

# Uploads (optional)
# UPLOAD_DIR=./uploads
